# WeStay Backend Environment Variables
# Copy this to .env and customize for your environment

# Server
PORT=3456
NODE_ENV=development

# JWT — CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-secret-key-here

# Database
DB_PATH=backend/data/westay.db

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:3456

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5

# ---- HTTPS / SSL ----
# Set to 'true' to enable HTTPS. Provide paths to SSL cert & key.
SSL_ENABLED=false
SSL_KEY_PATH=./certs/privkey.pem
SSL_CERT_PATH=./certs/fullchain.pem
# SSL_CA_PATH=./certs/chain.pem
# HTTP_REDIRECT_PORT=80

# ---- Payment Gateway (Stripe) ----
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ---- Email (SMTP / Nodemailer) ----
# Examples: smtp.gmail.com, smtp.mailgun.org, smtp.sendgrid.net
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@westay.my

# ---- WhatsApp (Meta Cloud API) ----
# Get from https://developers.facebook.com/apps/
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/{phone_id}/messages
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# ---- File Upload ----
UPLOAD_MAX_SIZE=10485760
UPLOAD_MAX_FILES=5

# ---- Logging ----
LOG_LEVEL=debug
